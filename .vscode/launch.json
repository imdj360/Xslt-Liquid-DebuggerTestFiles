{
  "version": "0.2.0",
  "configurations": [

    // ── DotLiquid Templates ──────────────────────────────────────────────────

    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: invoice-flat (JSON → JSON)",
      "template": "${workspaceFolder}/TestLiquid/json-to-json/invoice-flat.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: sales-order-transform (JSON → JSON)",
      "template": "${workspaceFolder}/TestLiquid/json-to-json/sales-order-transform.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: person-transform (JSON → JSON)",
      "template": "${workspaceFolder}/TestLiquid/json-to-json/person-transform.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: dotliquid-features (JSON → JSON)",
      "template": "${workspaceFolder}/TestLiquid/json-to-json/dotliquid-features.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: order-to-xml (JSON → XML)",
      "template": "${workspaceFolder}/TestLiquid/json-to-xml/order-to-xml.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: customer-to-xml (JSON → XML)",
      "template": "${workspaceFolder}/TestLiquid/json-to-xml/customer-to-xml.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: email-notification (JSON → HTML)",
      "template": "${workspaceFolder}/TestLiquid/json-to-html/email-notification.liquid"
    },
    {
      "type": "dotliquid",
      "request": "launch",
      "name": "Liquid: shipping-label (JSON → plain text)",
      "template": "${workspaceFolder}/TestLiquid/json-to-text/shipping-label.liquid"
    },

    // ── XSLT Templates (Compiled / XSLT 1.0) ─────────────────────────────────

    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: ShipmentConf (compiled)",
      "engine": "compiled",
      "stylesheet": "${workspaceFolder}/TestXslt/compiled/ShipmentConfv1.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/ShipmentConf.xml",
      "stopOnEntry": false
    },
    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: foreach-test (compiled)",
      "engine": "compiled",
      "stylesheet": "${workspaceFolder}/TestXslt/compiled/foreach-test.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/foreach-test.xml",
      "stopOnEntry": false
    },
    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: step-into-test (compiled)",
      "engine": "compiled",
      "stylesheet": "${workspaceFolder}/TestXslt/compiled/step-into-test.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/step-into-test.xml",
      "stopOnEntry": true
    },
    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: sample inline C# (compiled)",
      "engine": "compiled",
      "stylesheet": "${workspaceFolder}/TestXslt/compiled/sample-inline-cs.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/sample.xml",
      "stopOnEntry": false
    },

    // ── XSLT Templates (Saxon / XSLT 2.0 + 3.0) ──────────────────────────────

    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: ShipmentConf v2 (Saxon)",
      "engine": "saxonnet",
      "stylesheet": "${workspaceFolder}/TestXslt/saxon/ShipmentConfv2.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/ShipmentConf.xml",
      "stopOnEntry": false
    },
    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: ShipmentConf v3 (Saxon)",
      "engine": "saxonnet",
      "stylesheet": "${workspaceFolder}/TestXslt/saxon/ShipmentConfv3.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/ShipmentConf.xml",
      "stopOnEntry": false
    },
    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: foreach v3 (Saxon)",
      "engine": "saxonnet",
      "stylesheet": "${workspaceFolder}/TestXslt/saxon/ShipmentConfv3-foreach.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/ShipmentConf.xml",
      "stopOnEntry": false
    },
    {
      "type": "xslt",
      "request": "launch",
      "name": "XSLT: step-into-test (Saxon)",
      "engine": "saxonnet",
      "stylesheet": "${workspaceFolder}/TestXslt/saxon/step-into-test.xslt",
      "xml": "${workspaceFolder}/TestXslt/TestFiles/step-into-test.xml",
      "stopOnEntry": true
    }
  ]
}
